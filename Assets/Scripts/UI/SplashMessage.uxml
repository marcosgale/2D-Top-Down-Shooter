<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <engine:VisualElement name="SplashMessageContainer" style="flex-grow: 1; position: absolute; width: 100%; height: 100%; align-items: center; justify-content: center; display: flex;">
        <engine:Label name="SplashMessageLabel" text="You must defeat all enemies before advancing!" style="font-size: 48px; color: rgb(255, 255, 255); -unity-text-align: middle-center; -unity-font-style: bold; text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8); padding: 20px; white-space: normal; flex-wrap: wrap; max-width: 80%;" />
    </engine:VisualElement>
</engine:UXML>
